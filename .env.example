# Prophet Central - 环境变量配置

# ===== AI API Keys =====
# Anthropic Claude API Key (必需)
ANTHROPIC_API_KEY=sk-ant-xxxxx

# ===== GitHub自动营销配置 =====
# GitHub Personal Access Token
# 需要的权限: repo, discussions:write
# 获取方式: https://github.com/settings/tokens
GITHUB_TOKEN=ghp_xxxxx

# GitHub仓库（格式: owner/repo）
# 示例: prophet-ai/prophet
GITHUB_REPO=your-username/prophet

# ===== 服务器配置 =====
# Prophet Central服务器端口
PORT=3001

# ===== 可选配置 =====
# 日志级别
LOG_LEVEL=info

# 是否启用调试模式
DEBUG=false
