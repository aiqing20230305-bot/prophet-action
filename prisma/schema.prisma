// Prophet Central Database Schema
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// 项目表
model Project {
  id            String    @id @default(uuid())
  name          String
  type          String?
  path          String?
  apiKey        String    @unique
  createdAt     DateTime  @default(now())
  lastActiveAt  DateTime?
  metadata      Json?

  executions    Execution[]
  memories      Memory[]
  swarmSimulations SwarmSimulation[]

  @@map("projects")
}

// 任务执行记录
model Execution {
  id           String    @id @default(uuid())
  projectId    String
  taskId       String
  description  String
  status       String
  result       Json?
  startedAt    DateTime  @default(now())
  completedAt  DateTime?
  durationMs   Int?

  project      Project   @relation(fields: [projectId], references: [id])

  @@map("executions")
}

// 全局记忆
model Memory {
  id              String    @id @default(uuid())
  projectId       String
  type            String
  content         Json
  importance      Float
  tags            String[]
  createdAt       DateTime  @default(now())
  accessedCount   Int       @default(0)
  lastAccessedAt  DateTime?

  project         Project   @relation(fields: [projectId], references: [id])

  @@map("memories")
}

// 洞察
model Insight {
  id                    String    @id @default(uuid())
  sourceProjectId       String?
  type                  String
  description           String
  confidence            Float
  applicableToProjects  String[]
  createdAt             DateTime  @default(now())
  appliedCount          Int       @default(0)

  @@map("insights")
}

// 跨项目模式
model CrossProjectPattern {
  id            String    @id @default(uuid())
  patternType   String
  projects      String[]
  description   String
  frequency     Int
  effectiveness Float
  discoveredAt  DateTime  @default(now())

  @@map("cross_project_patterns")
}

// 进化指标
model EvolutionMetric {
  id         String   @id @default(uuid())
  projectId  String
  timestamp  DateTime @default(now())
  metrics    Json
  globalRank Int?

  @@map("evolution_metrics")
}

// 蜂群模拟记录
model SwarmSimulation {
  id            String         @id @default(uuid())
  projectId     String?
  scenario      String
  agentCount    Int
  steps         Int
  result        Json
  patterns      Json[]
  confidence    Float
  createdAt     DateTime       @default(now())

  project       Project?       @relation(fields: [projectId], references: [id])
  swarmPatterns SwarmPattern[]

  @@map("swarm_simulations")
}

// 智能体人格档案
model AgentProfile {
  id              String   @id @default(uuid())
  role            String
  personality     Json
  expertise       String[]
  biases          String[]
  createdAt       DateTime @default(now())
  simulationCount Int      @default(0)
  accuracyScore   Float    @default(0.5)

  @@map("agent_profiles")
}

// 蜂群涌现模式
model SwarmPattern {
  id            String          @id @default(uuid())
  simulationId  String
  patternType   String
  description   String
  confidence    Float
  participants  String[]
  createdAt     DateTime        @default(now())

  simulation    SwarmSimulation @relation(fields: [simulationId], references: [id])

  @@map("swarm_patterns")
}
